#!/usr/bin/env bash
#
# 자주 쓰는 명령을 모아둔 실행 스크립트.
#
#   ./gen setup     가상환경 생성 + 의존성 설치
#   ./gen commit    커밋 메시지 생성
#   ./gen pr        PR 초안 생성
#   ./gen check     검증 시나리오 일괄 실행
#
# commit / pr 뒤에 붙인 옵션은 그대로 main.py 로 전달된다.
#   ./gen commit --temperature 1.0

set -euo pipefail

cd "$(dirname "$0")"

VENV=".venv"
PYTHON="$VENV/bin/python"
PIP="$VENV/bin/pip"

info() { printf '[INFO] %s\n' "$1"; }
fail() { printf '[ERROR] %s\n' "$1" >&2; exit 1; }

# .env 가 있으면 환경변수로 읽어들인다. 이미 export 된 값이 있으면 그쪽이 우선이다.
load_env() {
  if [ -n "${AI_API_KEY:-}" ]; then
    return
  fi
  if [ -f .env ]; then
    set -a
    # shellcheck disable=SC1091
    . ./.env
    set +a
    info ".env 에서 AI_API_KEY 를 불러왔습니다."
  fi
}

require_venv() {
  [ -x "$PYTHON" ] || fail "가상환경이 없습니다. 먼저 ./gen setup 을 실행하세요."
}

# 3.10 이상 인터프리터를 찾는다. python 은 셸 alias 인 경우가 있어
# 스크립트에서는 잡히지 않으므로 후보를 차례로 확인한다.
find_python() {
  for candidate in python3.13 python3.12 python3.11 python3.10 python3 python; do
    if command -v "$candidate" >/dev/null 2>&1; then
      if "$candidate" -c 'import sys; sys.exit(0 if sys.version_info >= (3, 10) else 1)' 2>/dev/null; then
        echo "$candidate"
        return 0
      fi
    fi
  done
  return 1
}

cmd_setup() {
  local base
  base="$(find_python)" || fail "Python 3.10 이상을 찾을 수 없습니다."
  info "인터프리터: $base ($("$base" --version 2>&1))"

  if [ -d "$VENV" ]; then
    info "$VENV 가 이미 있습니다. 그대로 사용합니다."
  else
    info "$VENV 생성 중..."
    "$base" -m venv "$VENV"
  fi

  info "의존성 설치 중..."
  "$PIP" install --quiet --upgrade pip
  "$PIP" install --quiet -r requirements.txt

  info "설치 완료: $("$PYTHON" --version 2>&1), $("$PIP" freeze | grep -i '^requests==')"
  info "다음: export AI_API_KEY=\"발급받은_키\"  또는  echo 'AI_API_KEY=키' > .env"
}

cmd_run() {
  require_venv
  load_env
  "$PYTHON" main.py "$@"
}

cmd_check() {
  require_venv

  echo "=== 1. Python 버전 (3.10 이상 요구) ==="
  "$PYTHON" --version

  echo
  echo "=== 2. 의존성 ==="
  "$PIP" freeze | grep -i '^requests=='

  echo
  echo "=== 3. Git 미초기화 디렉토리 ==="
  local tmp
  tmp="$(mktemp -d)"
  ( cd "$tmp" && "$OLDPWD/$PYTHON" "$OLDPWD/main.py" commit 2>&1 | tail -1 ) || true
  rmdir "$tmp"

  echo
  echo "=== 4. API Key 미설정 ==="
  env -u AI_API_KEY "$PYTHON" main.py commit 2>&1 | tail -2 || true

  echo
  echo "=== 5. 인증 실패 ==="
  AI_API_KEY=invalid-key "$PYTHON" main.py commit 2>&1 | tail -2 || true

  echo
  echo "=== 6. safe-mode 마스킹 ==="
  "$PYTHON" - <<'PY'
from gitgen.sanitizer import mask_secrets
sample = (
    'OPENAI_KEY=sk-abcdefghijklmnop1234567890\n'
    'DB_PASSWORD="hunter2"\n'
    'contact = "alice@example.com"\n'
    'SAFE_VALUE=hello\n'
)
out, n = mask_secrets(sample)
print(out, end="")
print(f"-> {n}개 마스킹 (SAFE_VALUE 는 그대로여야 정상)")
PY

  echo
  echo "=== 7. 출력 형식 검증 ==="
  "$PYTHON" - <<'PY'
from gitgen.validator import validate_commit, validate_pr

r = validate_commit("feat: " + "가" * 90)
print(f"긴 커밋 제목 -> {len(r.text)}자, 경고 {len(r.warnings)}건")

r = validate_pr("제목\n\n## Why\n- 이유\n\n## What\n- 변경")
print(f"PR 섹션 누락  -> 경고 {len(r.warnings)}건: {r.warnings}")
PY

  echo
  info "검증 완료. 실제 생성은 ./gen commit 으로 확인하세요."
}

usage() {
  sed -n '3,12p' "$0" | sed 's/^# \{0,1\}//'
}

case "${1:-}" in
  setup)          shift; cmd_setup ;;
  commit|pr)      cmd_run "$@" ;;
  check)          shift; cmd_check ;;
  ""|-h|--help)   usage ;;
  *)              fail "알 수 없는 명령: $1 (사용법: ./gen --help)" ;;
esac
